#include <stdio.h>
#include <stdlib.h>

typedef struct lista {
    int info;
    struct lista* prox;
} Lista;

Lista* insere(Lista* l, int i) {
    Lista* novo = (Lista*) malloc(sizeof(Lista));
    novo->info = i;
    novo->prox = l;
    return novo;
}

void imprime(Lista* l) {
    Lista* p;
    for (p = l; p != NULL; p = p->prox) {
        printf("%d -> ", p->info);
    }
    printf("NULL\n");
}

Lista* remove_por_posicao(Lista* l, int pos) {
    if (l == NULL) return NULL;

    if (pos == 0) {
        Lista* aux = l;
        l = l->prox;
        free(aux);
        return l;
    }

    Lista* ant = l;
    int i = 0;

    while (ant != NULL && i < pos - 1) {
        ant = ant->prox;
        i++;
    }

    if (ant == NULL || ant->prox == NULL) {
        printf("Posicao %d invalida!\n", pos);
        return l;
    }

    Lista* atual = ant->prox;
    ant->prox = atual->prox;
    free(atual);

    return l;
}

int main(void) {
    Lista* l = NULL;
    l = insere(l, 70);
    l = insere(l, 60);
    l = insere(l, 50);

    printf("Antes da remocao: ");
    imprime(l);

    l = remove_por_posicao(l, 1);

    printf("Depois da remocao: ");
    imprime(l);

    return 0;
}
