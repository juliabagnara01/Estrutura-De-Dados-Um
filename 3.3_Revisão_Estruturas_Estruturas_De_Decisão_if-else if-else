#include <stdio.h>
int main() {
  float nota;
  int frequencia;

  printf("Digite a nota do aluno: ");
  scanf("%f", &nota);

  printf("Digite a frequencia do aluno (em %%): ");
  scanf("%d", &frequencia);

  if (nota >= 6 && frequencia >= 75) {
    printf("Aluno aprovado.\n");
  } else if (nota >= 4 && frequencia >= 75) {
    printf("Aluno em recuperacao.\n");
  } else {
    printf("Aluno reprovado.\n");
  }

  return 0;
} 
