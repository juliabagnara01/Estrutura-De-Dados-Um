#include <stdio.h>
#include <stdlib.h>

typedef struct lista {
    int info;
    struct lista* prox;
} Lista;

Lista* insere(Lista* l, int i) {
    Lista* novo = (Lista*) malloc(sizeof(Lista));
    novo->info = i;
    novo->prox = l;
    return novo;
}

void imprime(Lista* l) {
    Lista* p;
    for (p = l; p != NULL; p = p->prox) {
        printf("%d -> ", p->info);
    }
    printf("NULL\n");
}

// Funcao para remover o ultimo no da lista encadeada
Lista* remove_ultimo(Lista* l) {
    // Caso 1: Lista vazia
    if (l == NULL) {
        return NULL;
    }
    // Caso 2: Lista com apenas um elemento
    if (l->prox == NULL) {
        free(l);
        return NULL; // A lista agora passa a ficar vazia
    }

    // Caso 3: Lista com dois ou mais elementos
    Lista* p = l;
    // O loop para exatamente quando 'p' vira o penultimo elemento
    while (p->prox->prox != NULL) {
        p = p->prox;
    }

    free(p->prox);    
    p->prox = NULL;   
    return l;
}

// Funcao para limpar toda a lista da memoria (evita memory leak)
void libera(Lista* l) {
    Lista* p = l;
    while (p != NULL) {
        Lista* t = p->prox; 
        free(p);            
        p = t;             
    }
}

int main(void) {
    Lista* minhaLista = NULL;
    minhaLista = insere(minhaLista, 50);
    minhaLista = insere(minhaLista, 40);
    minhaLista = insere(minhaLista, 30);
    
    printf("Lista original: ");
    
    imprime(minhaLista);
    
    minhaLista = remove_ultimo(minhaLista);
    
    printf("Lista apos remover o ultimo: ");
    
    imprime(minhaLista);

    libera(minhaLista);
    printf("Memoria da lista completamente liberada!\n");
    return 0;
}
