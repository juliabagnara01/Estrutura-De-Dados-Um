#include <stdio.h>
// Funcao que recebe os enderecos de memoria e realiza a troca
void troca(int *a, int *b) {
    int temp = *a; // Guarda temporariamente o valor contido no ponteiro a
    *a = *b;       // Atribui o valor do ponteiro b ao ponteiro a
    *b = temp;     // Atribui o valor guardado em temp ao ponteiro b
}

int main() {
    int x = 8;
    int y = 10;
    printf("Valores antes da troca: x = %d, y = %d\n", x, y);
    // Passa os enderecos de memoria de x e y para a funcao
    troca(&x, &y);
    printf("Valores apos a troca: x = %d, y = %d\n", x, y);
    return 0;
}
