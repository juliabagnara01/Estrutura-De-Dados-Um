#include <stdio.h>
#include <stdlib.h>

typedef struct lista {
    int info;
    struct lista* prox;
} Lista;

Lista* insere(Lista* l, int i) {
    Lista* novo = (Lista*) malloc(sizeof(Lista));
    novo->info = i;
    novo->prox = l;
    return novo;
}

void imprime(Lista* l) {
    Lista* p;
    for (p = l; p != NULL; p = p->prox) {
        printf("%d -> ", p->info);
    }
    printf("NULL\n");
}

Lista* remove_por_valor(Lista* l, int v) {
    Lista* ant = NULL;
    Lista* p = l;

    while (p != NULL && p->info != v) {
        ant = p;
        p = p->prox;
    }

    if (p == NULL) {
        printf("Valor %d nao encontrado.\n", v);
        return l;
    }

    if (ant == NULL) {
        l = p->prox;
    } else {
        ant->prox = p->prox;
    }

    free(p);
    return l;
}

int main(void) {
    Lista* l = NULL;
    l = insere(l, 10);
    l = insere(l, 25);
    l = insere(l, 40);

    printf("Antes da remocao: ");
    imprime(l);

    l = remove_por_valor(l, 25);

    printf("Depois da remocao: ");
    imprime(l);

    return 0;
}
