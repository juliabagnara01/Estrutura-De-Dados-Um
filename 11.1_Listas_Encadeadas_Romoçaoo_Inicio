#include <stdio.h>
#include <stdlib.h>

typedef struct lista {
    int info;
    struct lista* prox;
} Lista;

Lista* insere(Lista* l, int i) {
    Lista* novo = (Lista*) malloc(sizeof(Lista));
    novo->info = i;
    novo->prox = l;
    return novo;
}


void imprime(Lista* l) {
    Lista* p;
    for (p = l; p != NULL; p = p->prox) {
        printf("%d -> ", p->info);
    }
    printf("NULL\n");
}

// Funcao que remove o elemento do inicio 
Lista* remove_inicio(Lista* l) {
    if (l == NULL) {
        printf("Lista vazia! Nada para remover.\n");
        return NULL;
    }
    
    Lista* aux = l; 
    l = l->prox;    
    free(aux);      
    
    return l; 
}

int main(void) {
    Lista* l = NULL;
    l = insere(l, 10);
    l = insere(l, 20);
    l = insere(l, 30);

    printf("Antes da remocao: ");
    imprime(l); // Vai mostrar: 30 -> 20 -> 10 -> NULL
    
    l = remove_inicio(l);
   
    printf("Depois de remover o inicio: ");
    imprime(l); // Vai mostrar: 20 -> 10 -> NULL
    
    return 0;
}
